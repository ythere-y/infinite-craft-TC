# 本文件只用于本地 FastAPI 开发。复制为 .env 后填写成员私发的 DeepSeek Key。
# 不要在本文件或任何 Git 提交中填写真实密钥。
APP_ENV=dev

# DeepSeek OpenAI-compatible API
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
LLM_TIMEOUT=20
LLM_MAX_RETRIES=0
LLM_REASONING_EFFORT=
LLM_THINKING_ENABLED=false

# 本地服务。Docker Compose 会固定使用容器内 Redis DB 1；
# REDIS_URL 同时供 ./run.sh 或手动启动 FastAPI 使用。
HOST=0.0.0.0
PORT=8000
REDIS_URL=redis://127.0.0.1:16739/1

# Makers 生产环境的 MAKERS_MODELS_KEY、AI_GATEWAY_*、ADMIN_TOKEN、
# DASHBOARD_PUBLIC 和 MODEL_CALLS_PER_MINUTE 请在 Makers 控制台配置，
# 不属于成员本机 .env。
