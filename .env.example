# 仅填写变量名和安全示例；不要在本文件写入任何真实密钥或私有地址。
APP_ENV=dev
HOST=0.0.0.0
PORT=8000
REDIS_URL=redis://127.0.0.1:16739/1

# OpenAI-compatible provider. Keep real credentials in ignored .env only.
# Makers Edge Functions 优先读取 AI_GATEWAY_*，也兼容下方原 FastAPI 变量。
AI_GATEWAY_API_KEY=
AI_GATEWAY_BASE_URL=https://ai-gateway.edgeone.link/v1
AI_GATEWAY_MODEL=@makers/deepseek-v4-flash
LLM_API_KEY=
MAKERS_MODELS_KEY=
LLM_BASE_URL=https://ai-gateway.edgeone.link/v1
LLM_MODEL=@makers/deepseek-v4-flash
LLM_TIMEOUT=15
LLM_MAX_RETRIES=2
