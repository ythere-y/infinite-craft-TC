# 仅填写变量名和安全示例；不要在本文件写入任何真实密钥或私有地址。
#
# Makers-first 本地开发：
# `npm run makers:dev` 会在被 Git 忽略的 .env 中强制设置 APP_ENV=dev，
# 从而只使用 test_dev → infinite_craft_dev。不要在共享的 Makers 控制台
# 环境变量中设置 APP_ENV=dev，否则后续生产部署也会使用开发 KV。
APP_ENV=dev

# Makers Models。成员运行 edgeone makers link / env pull 后由 CLI 写入本机 .env。
MAKERS_MODELS_KEY=
AI_GATEWAY_API_KEY=
AI_GATEWAY_BASE_URL=https://ai-gateway.edgeone.link/v1
AI_GATEWAY_MODEL=@makers/deepseek-v4-flash
LLM_TIMEOUT=20
MODEL_CALLS_PER_MINUTE=20

# Makers 管理/分析接口未设置 ADMIN_TOKEN 时默认关闭。
ADMIN_TOKEN=
DASHBOARD_PUBLIC=0

# ------------------------------------------------------------------
# Legacy FastAPI / Redis / SQLite 本地备用配置，不参与 Makers 运行。
# ------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
REDIS_URL=redis://127.0.0.1:16739/1
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
LLM_MAX_RETRIES=0
LLM_REASONING_EFFORT=
LLM_THINKING_ENABLED=false
